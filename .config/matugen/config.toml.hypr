[templates.gtk3]
# input_path = 'path/to/template'
input_path = "~/.config/matugen/templates/gtk.conf"
# output_path = '~/.config/gtk-3.0/colors.css'
output_path = '~/.config/gtk-3.0/gtk.css'
post_hook = 'gsettings set org.gnome.desktop.interface gtk-theme ""; gsettings set org.gnome.desktop.interface gtk-theme adw-gtk3-{{mode}}'

[templates.gtk4]
# input_path = 'path/to/template'
input_path = "~/.config/matugen/templates/gtk.conf"
# output_path = '~/.config/gtk-4.0/colors.css'
output_path = '~/.config/gtk-4.0/gtk.css'

[templates.startpage]
input_path = "~/.config/matugen/templates/startpage.conf"
output_path = "~/.config/myZen/colors.css"
post_hook = "ln -sfn {{image}} ~/.config/myZen/current"

