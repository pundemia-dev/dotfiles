[config]
reload_apps = true

[templates.caelestia_wallpaper]
pre_hook = "mkdir -p ~/.local/state/caelestia/wallpaper" # && ~/.config/quickshell/pShell/scripts/wallSet_postHook.sh"
input_path = "~/.config/matugen/templates/caelestia_wallpaper.conf"
output_path = "~/.local/state/caelestia/wallpaper/path.txt"
post_hook = "~/.config/quickshell/tempShell/scripts/wallSet_postHook.sh"

[templates.caelestia_scheme]
pre_hook = "mkdir -p ~/.local/state/caelestia"
input_path = "~/.config/matugen/templates/caelestia_scheme.conf"
output_path = "~/.local/state/caelestia/scheme.json"

[templates.pshell_scheme]
pre_hook = "mkdir -p ~/.local/state/pShell"
input_path = "~/.config/matugen/templates/caelestia_scheme.conf"
output_path = "~/.local/state/pShell/scheme.json"

[templates.kitty]
input_path = "~/.config/matugen/templates/kitty-colors.conf"
output_path = "~/.config/kitty/themes/colors.conf"
# post_hook = "kitty @ set-colors -a ~/.config/kitty/themes/colors.conf"
post_hook = "kitty +kitten themes --reload-in=all colors"

[templates.flameshot]
input_path = "~/.config/matugen/templates/flameshot-colors.conf"
output_path = "~/.config/flameshot/colors.ini"
post_hook = "~/.config/flameshot/updater.py ~/.config/flameshot/colors.ini ~/.config/flameshot/custom.ini ~/.config/flameshot/flameshot.ini"

[templates.zen-chrome]
input_path = "~/.config/matugen/templates/userChrome.css.tpl"
output_path = "/home/pundemia/.zen/77t23jgn.Default (release)/chrome/userChrome.css"

[templates.zen-content]
input_path = "~/.config/matugen/templates/userContent.css.tpl"
output_path = "/home/pundemia/.zen/77t23jgn.Default (release)/chrome/userContent.css"
# echo $HOME/.zen/*.Default\ \(release\)/chrome

[templates.vencord]
input_path = "~/.config/matugen/templates/discord.conf"
output_path = "~/.config/vesktop/themes/pShell.theme.css"

