# font_family      Roboto#ZedMono Nerd Font Mono
font_family     Dank Mono
font_size 12.0
bold_font        auto
italic_font      auto
bold_italic_font auto
cursor_trail 3
window_padding_width 10
tab_bar_style powerline 
tab_activity_symbol "󰗖 "
background_opacity 0.7
# shell nu
shell fish
map kitty_mod+Q new_window
map kitty_mod+shift+H move_window left
map kitty_mod+shift+J move_window down
map kitty_mod+shift+K move_window up
map kitty_mod+shift+L move_window right
map kitty_mod+shift+left move_window left
map kitty_mod+shift+down move_window down
map kitty_mod+shift+up move_window up
map kitty_mod+shift+right move_window right
map kitty_mod+H neighboring_window left
map kitty_mod+J neighboring_window down
map kitty_mod+K neighboring_window up
map kitty_mod+L neighboring_window right
map kitty_mod+left neighboring_window left
map kitty_mod+down neighboring_window down
map kitty_mod+up neighboring_window up
map kitty_mod+right neighboring_window right
map kitty_mod+tab        next_tab
map kitty_mod+shift+tab previous_tab
map kitty_mod+t new_tab
map kitty_mod+S toggle_layout tall
symbol_map U+efc5 CaskaydiaCove Nerd Font
# Nerd Fonts v3.3.0
# Сдвигает базовую линию. 
# Попробуйте отрицательные значения (-1, -2), чтобы опустить текст,
# или положительные, если нужно поднять.
# modify_font baseline -1.5
# modify_font line_height 135%
symbol_map U+0400-U+052F BlexMono Nerd Font
symbol_map U+e000-U+e00a,U+ea60-U+ebeb,U+e0a0-U+e0c8,U+e0ca,U+e0cc-U+e0d7,U+e200-U+e2a9,U+e300-U+e3e3,U+e5fa-U+e6b7,U+e700-U+e8ef,U+ed00-U+efc1,U+f000-U+f2ff,U+f000-U+f2e0,U+f300-U+f381,U+f400-U+f533,U+f0001-U+f1af0 Symbols Nerd Font Mono
# include mat777.conf


# BEGIN_KITTY_THEME
# Colors
include current-theme.conf
# END_KITTY_THEME
