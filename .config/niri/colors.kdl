layout {
    focus-ring {
        active-color "#c4c5d6"
        inactive-color "#929092"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#c4c5d6"
        inactive-color "#929092"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#c4c5d6"
        inactive-color "#929092"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#c4c5d680"
    }
}

